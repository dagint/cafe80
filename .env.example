# Cafe80 – RustDesk deployment
# Copy to .env and fill in real values. Never commit .env.
# Use scripts/sync-secrets-to-github.sh to push these to GitHub Actions secrets.

# --- VPS / GitHub Actions deploy ---
VPS_HOST=your-vps.example.com
SSH_PORT=22
DEPLOY_USER=deploy
# SSH private key for GitHub Actions — stored as base64 to avoid newline issues.
# Generate: cat ~/.ssh/id_ed25519 | base64 -w 0
# (On macOS use: base64 -i ~/.ssh/id_ed25519 | tr -d '\n')
SSH_PRIVATE_KEY_B64=

# --- RustDesk server (used on VPS in deploy/.env) ---
# Public hostname or IP clients will use (ID/Relay server setting)
RUSTDESK_RELAY_HOST=your-vps.example.com
# Optional: custom key file names under data/ (defaults generated by hbbs)
# RUSTDESK_KEY_PUB=id_ed25519.pub
# RUSTDESK_KEY_PRIV=id_ed25519

# --- Tailscale ---
# VPS join key (one-time; used with ubuntu-tailscale.sh). Tag: tag:rustdesk-server.
TAILSCALE_AUTHKEY=
# TAILSCALE_TAG=tag:rustdesk-server

# GitHub Actions key (ephemeral, pre-authorized). Tag: tag:github-actions.
# The runner joins the tailnet for the duration of each deploy job then auto-removes.
# VPS_HOST above should be the VPS Tailscale hostname or 100.x IP so SSH goes over Tailscale.
TAILSCALE_AUTHKEY_GH=

# --- Optional: backup (later; store only on server or in GitHub Secrets) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# RCLONE_GDRIVE_CONFIG=
